# Orchestra Research — Frontend Environment Variables
# Copy to .env.local for local development

# Backend API base URL (proxied via next.config.js in dev, set directly in prod)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: Override the default backend URL for API routes
# Only needed if you're running backend on a non-standard port
# NEXT_PUBLIC_API_BASE=http://localhost:8000/api
